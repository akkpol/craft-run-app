# Template for system owner / deployer to fill in.
# These values should be entered by the person setting up the system,
# usually in Vercel Project Environment Variables or a local .env.local file.
# Developers should not hardcode real secrets in the repo.

# BACKOFFICE ACCESS ALLOWLIST
# Supabase Auth handles passwords and account recovery.
# These env vars only decide which authenticated emails may enter /admin.
# ADMIN_ALLOWED_EMAILS accepts comma, newline, or semicolon separated emails.
ADMIN_ALLOWED_EMAILS="admin@example.com,ops@example.com"
# Optional single-email fallback kept for compatibility with older setups.
ADMIN_EMAIL="admin@example.com"

# LINE MESSAGING API
# Filled by the system owner from LINE Developers Console > Messaging API.
# Used by the server to verify webhook signatures and send reply/push messages.
LINE_CHANNEL_ACCESS_TOKEN="LINE_MESSAGING_API_CHANNEL_ACCESS_TOKEN"
LINE_CHANNEL_SECRET="LINE_MESSAGING_API_CHANNEL_SECRET"

# LIFF
# Filled by the system owner from LINE Developers Console > LIFF.
# Used by the LIFF web app that opens inside LINE.
# Endpoint URL should be: https://your-app.vercel.app/liff
LIFF_ID="YOUR_LIFF_ID"
NEXT_PUBLIC_LIFF_ID="YOUR_LIFF_ID"

# SUPABASE
# Filled by the system owner from Supabase Project Settings.
# Use the new 2026 key types only.
# NEXT_PUBLIC_* is safe for browser/SSR use.
# SUPABASE_SECRET_KEY is server-only.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SECRET_KEY="sb_secret_xxx"

# APP BASE URL
# Filled by the system owner.
# Public app URL used to build links for quote/status pages and webhook callbacks.
NEXT_PUBLIC_BASE_URL="https://your-app.vercel.app"

# OPTIONAL CUSTOMER FILE UPLOAD LINK
# Temporary shortcut for receiving artwork files before native uploads are built.
# Can be a Google Drive, Google Form, Dropbox File Request, or OneDrive upload link.
NEXT_PUBLIC_CUSTOMER_UPLOAD_URL="https://drive.google.com/..."
NEXT_PUBLIC_CUSTOMER_UPLOAD_LABEL="ส่งไฟล์งาน / รูปอ้างอิง"

# VERCEL
# VERCEL_OIDC_TOKEN is not a normal app setting for users to fill.
# It is generated by Vercel CLI / integrations when needed.
CRON_SECRET="set-a-long-random-secret-for-vercel-crons"
