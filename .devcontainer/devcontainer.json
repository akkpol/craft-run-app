{
  "name": "FOGUS Dev",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bookworm",
  "hostRequirements": { "cpus": 2, "memory": "8gb", "storage": "32gb" },
  "features": { "ghcr.io/devcontainers-extra/features/supabase-cli:1": {} },
  "postCreateCommand": "npm ci",
  "forwardPorts": [3000, 54321, 54323],
  "portsAttributes": {
    "3000": { "label": "Next.js Dev", "onAutoForward": "openBrowserOnce" },
    "54321": { "label": "Supabase API", "onAutoForward": "silent" },
    "54323": { "label": "Supabase Studio", "onAutoForward": "silent" }
  },
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint","bradlc.vscode-tailwindcss","esbenp.prettier-vscode","supabase.vscode-supabase-extension","github.copilot","github.copilot-chat"],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  }
}
