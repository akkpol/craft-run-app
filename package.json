{
  "name": "fogus",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --max-old-space-size=8192 ./node_modules/next/dist/bin/next dev",
    "dev:webpack": "node --max-old-space-size=12288 ./node_modules/next/dist/bin/next dev --webpack",
    "prebuild": "node scripts/check-line-liff-env.mjs",
    "build": "next build",
    "start": "next start",
    "test": "node scripts/run-tests.mjs",
    "test:node": "node scripts/run-tests.mjs --node-only",
    "test:vitest": "node scripts/run-tests.mjs --vitest-only",
    "lint": "eslint .",
    "check:line-liff-env": "node scripts/check-line-liff-env.mjs --strict",
    "check:workflow-policy": "node scripts/workflow-policy-smoke.mjs",
    "sandbox:help": "sandbox --help",
    "sandbox:login": "sandbox login",
    "sandbox:list": "sandbox list --all",
    "sandbox:node": "sandbox run --rm --runtime node24 -- node --version",
    "sandbox:python": "sandbox run --rm --runtime python3.13 -- python3 --version",
    "sandbox:locked": "sandbox create --runtime node24 --timeout 30m --network-policy deny-all --connect"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/stitch-sdk": "^0.1.0",
    "@line/bot-sdk": "^9.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "next": "^16.2.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "sandbox": "^2.5.10",
    "shadcn": "^4.5.0",
    "supabase": "^2.95.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.0",
    "vitest": "^4.1.5"
  }
}
